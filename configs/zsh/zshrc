glogf() {
  local file="$1"

  if [[ -z "$file" ]]; then
    echo "Usage: glogf <file>"
    return 1
  fi

  git log --all \
    --date=short \
    --pretty=format:"\
%C(bold yellow)%h%C(reset)  \
%C(green)%ad%C(reset)  \
%C(cyan)%<(12,trunc)%an%C(reset)  \
%C(white)%<(60,trunc)%s%C(reset)" \
    -- "$file" \
  | fzf --ansi \
      --delimiter=" " \
      --preview "git -c core.pager=cat --no-pager show --color=always {1} -- \"$file\"" \
      --preview-window=right:70%
}

