# =================================================================
# wsl configuration
# =================================================================

function set-wsl-proxy() {
  local host_ip
  host_ip=$(ip route | grep '^default' | awk '{print $3}')

  if [[ -z "$host_ip" ]]; then
    echo "❌ 无法获取宿主机 IP。"
    return 1
  fi

  export http_proxy="http://${host_ip}:7890"
  export https_proxy="http://${host_ip}:7890"

  echo "✅ 代理已设置:"
  echo "http_proxy=$http_proxy"
  echo "https_proxy=$https_proxy"
}

function unset-wsl-proxy() {
  unset http_proxy
  unset https_proxy
  echo "🧹 已清除代理设置。"
}

if grep -qEi "(Microsoft|WSL)" /proc/version &> /dev/null ; then
  alias e="powershell.exe start explorer.exe ."
  alias setproxy=set-wsl-proxy
  alias usetproxy=unset-wsl-proxy
fi


